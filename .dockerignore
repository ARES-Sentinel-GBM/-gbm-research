# Docker ignore file for ARES-GBM Research

# Git
.git
.gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints

# Results (generated output)
results/*
!results/.gitkeep

# Manuscript (optional, can be kept separate)
# manuscript/

# OS files
.DS_Store
Thumbs.db

# Qwen settings
.qwen/
